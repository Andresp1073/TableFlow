# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ── Database ────────────────────────────────────────────────────────────────
# Option A: Full connection string (takes precedence)
DATABASE_URL="mysql://root:password@localhost:3306/tableflow"

# Option B: Individual connection parameters (used if DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=tableflow
DATABASE_USER=root
DATABASE_PASSWORD=password

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Slow query threshold (milliseconds)
DB_SLOW_QUERY_THRESHOLD_MS=500

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# ── Timezone ────────────────────────────────────────────────────────────────
TZ=UTC

# ── Seeding (development only) ──────────────────────────────────────────────
# Default admin user created during seeding
SEED_ADMIN_EMAIL=admin@tableflow.io
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator

# Demo organization created during seeding
SEED_ORG_NAME=TableFlow Demo
SEED_ORG_SLUG=tableflow-demo
SEED_ORG_EMAIL=demo@tableflow.io

# Demo branch created during seeding
SEED_BRANCH_NAME=Downtown
SEED_BRANCH_SLUG=downtown
SEED_BRANCH_EMAIL=downtown@tableflow.io
SEED_BRANCH_PHONE=+1-555-0100
SEED_BRANCH_ADDRESS=123 Main St, New York, NY 10001
SEED_BRANCH_TIMEZONE=America/New_York
SEED_BRANCH_CUISINE=american
