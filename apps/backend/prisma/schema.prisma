// ============================================================================
// TableFlow — Prisma Schema (Complete Domain Model)
// ============================================================================
// Conventions:
//   - snake_case for MySQL table names (via @@map)
//   - camelCase for Prisma model fields
//   - UUID v4 for all primary keys: String @id @default(uuid()) @db.Char(36)
//   - created_at + updated_at on every mutable entity
//   - updated_by on mutable entities (UUID of staff who last modified)
//   - is_active for soft-disabling (never hard-delete reference data)
//   - Singular model names (User, Role, Branch)
//   - No Prisma enums (MySQL compatibility; validated at application layer)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & AUTHORIZATION
// ============================================================================

// ── User ───────────────────────────────────────────────────────────────────
// Staff accounts. Every authenticated user is a User.
// Customers are NOT users — they are Customer records.

model User {
  id                  String    @id @default(uuid()) @db.Char(36)
  organizationId      String    @db.Char(36)
  email               String    @unique @db.VarChar(255)
  passwordHash        String    @db.VarChar(255)
  firstName           String    @db.VarChar(100)
  lastName            String    @db.VarChar(100)
  phone               String?   @db.VarChar(20)
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  lockedAt            DateTime?
  lockedUntil         DateTime?
  lockReason          String?   @db.VarChar(255)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization            Organization              @relation(fields: [organizationId], references: [id])
  userRoles               UserRole[]                @relation("UserUserRoles")
  assignedUserRoles       UserRole[]                @relation("UserRoleAssigner")
  employees               Employee[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
  createdReservations     Reservation[]             @relation("CreatedBy")
  updatedReservations     Reservation[]             @relation("UpdatedBy")
  assignedReservations    Reservation[]             @relation("AssignedTo")

  @@index([organizationId])
  @@index([isActive])
  @@map("users")
}

// ── Role ───────────────────────────────────────────────────────────────────
// Defines a named role (Admin, Manager, Receptionist, Waiter).
// System roles (isSystem=true) cannot be deleted.

model Role {
  id           String   @id @default(uuid()) @db.Char(36)
  code         String   @db.VarChar(100)
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  restaurantId String?  @db.Char(36)
  isSystem     Boolean  @default(false)
  isDefault    Boolean  @default(false)
  priority     Int      @default(0)
  color        String?  @db.VarChar(7)
  icon         String?  @db.VarChar(50)
  status       String   @default("active") @db.VarChar(20)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization    Organization?  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userRoles        UserRole[]
  rolePermissions  RolePermission[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@index([status])
  @@map("roles")
}

// ── UserRole ───────────────────────────────────────────────────────────────
// Assigns a role to a user, scoped to a restaurant and optionally a branch.
// If branchId is NULL, the role applies restaurant-wide.
// Tracks assignment lifecycle: who assigned it, when, and its current status.

model UserRole {
  id           String    @id @default(uuid()) @db.Char(36)
  userId       String    @db.Char(36)
  roleId       String    @db.Char(36)
  restaurantId String    @db.Char(36)
  branchId     String?   @db.Char(36)
  assignedBy   String    @db.Char(36)
  assignedAt   DateTime  @default(now())
  expiresAt    DateTime?
  status       String    @default("active") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User         @relation("UserUserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  restaurant   Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedByUser User      @relation("UserRoleAssigner", fields: [assignedBy], references: [id])

  @@unique([userId, roleId, restaurantId])
  @@index([userId])
  @@index([roleId])
  @@index([restaurantId])
  @@index([branchId])
  @@index([status])
  @@map("user_roles")
}

// ── Permission ─────────────────────────────────────────────────────────────
// Granular system permission. code uses dot notation: "reservations.create"
// module groups permissions for UI organization (e.g., "reservations", "customers").

model Permission {
  id          String   @id @default(uuid()) @db.Char(36)
  code        String   @unique @db.VarChar(150)
  name        String   @db.VarChar(200)
  description String   @db.Text
  module      String   @db.VarChar(100)
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  riskLevel   String   @default("low") @db.VarChar(20)
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
  @@index([resource])
  @@map("permissions")
}

// ── RolePermission ─────────────────────────────────────────────────────────
// Junction — maps permissions to roles. Each assignment is uniquely identified
// by the (roleId, permissionId) pair.

model RolePermission {
  id           String   @id @default(uuid()) @db.Char(36)
  roleId       String   @db.Char(36)
  permissionId String   @db.Char(36)
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ── PasswordResetToken ─────────────────────────────────────────────────────
// One-time password reset tokens. Only one active token per user at a time.
// Tokens are hashed before storage; only the hash is persisted.

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  tokenHash String   @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// ── EmailVerificationToken ─────────────────────────────────────────────────
// One-time email verification tokens. Only one active token per user at a time.
// Tokens are hashed before storage; only the hash is persisted.

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Char(36)
  userId    String   @db.Char(36)
  tokenHash String   @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([tokenHash])
  @@map("email_verification_tokens")
}

// ── RefreshToken ───────────────────────────────────────────────────────────
// Tracks JWT refresh tokens for rotation and revocation.
// Each token represents an active session with device metadata.
// Token families group rotations from the same login session for reuse detection.

model RefreshToken {
  id             String    @id @default(uuid()) @db.Char(36)
  userId         String    @db.Char(36)
  tokenHash      String    @db.VarChar(255)
  accessTokenJti String?   @db.VarChar(255)
  ipAddress      String?   @db.VarChar(45)
  userAgent      String?   @db.VarChar(500)
  familyId       String    @db.Char(36)
  parentTokenId  String?   @db.Char(36)
  rotatedAt      DateTime?
  revokedAt      DateTime?
  reuseDetected  Boolean   @default(false)
  expiresAt      DateTime
  isRevoked      Boolean   @default(false)
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([accessTokenJti])
  @@index([familyId])
  @@index([parentTokenId])
  @@index([userId, isRevoked, expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// ORGANIZATION & BRANCHES
// ============================================================================

// ── Organization ───────────────────────────────────────────────────────────
// Tenant — a restaurant company. Root entity for multi-tenancy.

model Organization {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  legalName String?  @db.VarChar(255)
  taxId     String?  @db.VarChar(50)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  website   String?  @db.VarChar(500)
  address   String?  @db.Text
  logoUrl   String?  @db.VarChar(500)
  timezone  String   @default("UTC") @db.VarChar(50)
  currency  String   @default("USD") @db.VarChar(3)
  language  String   @default("en") @db.VarChar(5)
  status    String   @default("draft") @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  deletedBy String?  @db.Char(36)

  roles        Role[]
  branches     Branch[]
  users        User[]
  customers    Customer[]
  settings     OrganizationSetting[]
  restaurantSettings RestaurantSettings[]
  reservationPolicy ReservationPolicy?
  businessHours     BusinessHours?
  calendarExceptions CalendarException[]
  restaurantAssets   RestaurantAsset[]
  diningAreas        DiningArea[]
  tableTypes         TableType[]
  tables             RestaurantTable[]
  reservations Reservation[]
  auditLogs    AuditLog[]
  userRoles    UserRole[]

  @@index([status])
  @@map("organizations")
}

// ── RestaurantSettings ─────────────────────────────────────────────────────
// Typed operational settings for a restaurant (one-to-one with Organization).
// Separate aggregate from Restaurant — loaded and managed independently.

model RestaurantSettings {
  id                          String   @id @default(uuid()) @db.Char(36)
  restaurantId                String   @unique @db.Char(36)
  timezone                    String   @default("UTC") @db.VarChar(50)
  currency                    String   @default("USD") @db.Char(3)
  language                    String   @default("en") @db.VarChar(10)
  dateFormat                  String   @default("YYYY-MM-DD") @db.VarChar(20)
  timeFormat                  String   @default("HH:mm") @db.VarChar(20)
  weekStartsOn                Int      @default(0)
  taxPercentage               Decimal  @default(0) @db.Decimal(5, 2)
  serviceChargePercentage     Decimal  @default(0) @db.Decimal(5, 2)
  defaultReservationDuration  Int      @default(60)
  reservationBufferMinutes    Int      @default(15)
  allowWalkIns                Boolean  @default(true)
  autoConfirmReservations     Boolean  @default(false)
  maxReservationsPerCustomer  Int      @default(10)
  reservationCancellationHours Int     @default(24)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("restaurant_settings")
}

// ── BusinessHours ──────────────────────────────────────────────────────
// Operating hours for a restaurant (one-to-one with Organization).
// Separate aggregate — contains day schedules and opening periods.
// Designed for future: branches, holiday overrides, seasonal schedules.

model BusinessHours {
  id           String   @id @default(uuid()) @db.Char(36)
  restaurantId String   @unique @db.Char(36)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  periods    OpeningPeriod[]

  @@map("business_hours")
}

// ── CalendarException ──────────────────────────────────────────────────
// Overrides business hours for specific dates (holidays, closures, events).
// Multiple exceptions per restaurant; resolved by priority + date/type uniqueness.
// Designed for future resolver: Business Hours → Calendar Exception → Reservation Policy.
// Types: holiday, special_opening, temporary_closure, maintenance, private_event, seasonal_hours, emergency_closure

model CalendarException {
  id           String   @id @default(uuid()) @db.Char(36)
  restaurantId String   @db.Char(36)
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  type         String   @db.VarChar(30)
  date         DateTime @db.Date
  isClosed     Boolean  @default(false)
  openTime     String?  @db.VarChar(5)
  closeTime    String?  @db.VarChar(5)
  allDay       Boolean  @default(false)
  priority     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date, type])
  @@index([restaurantId, date])
  @@index([date])
  @@map("calendar_exceptions")
}

model OpeningPeriod {
  id              String   @id @default(uuid()) @db.Char(36)
  businessHoursId String   @db.Char(36)
  dayOfWeek       Int      // 1=Monday .. 7=Sunday
  openTime        Int      // Minutes from midnight (0-1439)
  closeTime       Int      // Minutes from midnight (0-1439)
  order           Int      // Display order for periods within the same day
  createdAt       DateTime @default(now())

  businessHours BusinessHours @relation(fields: [businessHoursId], references: [id], onDelete: Cascade)

  @@index([businessHoursId, dayOfWeek])
  @@map("opening_periods")
}

// ── RestaurantAsset ────────────────────────────────────────────────────
// Digital assets uploaded for a restaurant (logos, covers, gallery images, menus, etc.).
// Provider-agnostic: storageProvider field identifies the backend (local, s3, cloudinary).
// Primary flag supports exactly one primary asset per type per restaurant.

model RestaurantAsset {
  id              String   @id @default(uuid()) @db.Char(36)
  restaurantId    String   @db.Char(36)
  type            String   @db.VarChar(30)
  name            String   @db.VarChar(255)
  originalFilename String  @db.VarChar(500)
  mimeType        String   @db.VarChar(100)
  extension       String   @db.VarChar(20)
  size            Int
  width           Int?
  height          Int?
  storageProvider String   @db.VarChar(50)
  storageKey      String   @db.VarChar(500)
  publicUrl       String?  @db.VarChar(1000)
  isPrimary       Boolean  @default(false)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, type])
  @@index([restaurantId, isPrimary])
  @@map("restaurant_assets")
}

// ── ReservationPolicy ───────────────────────────────────────────────────
// Reservation policies and constraints per restaurant (one-to-one with Organization).
// Separate aggregate from Restaurant — loaded and managed independently.
// Defines business rules for reservations: party size, duration, advance booking,
// cancellation, walk-ins, auto-confirmation, and customer requirements.

model ReservationPolicy {
  id                                String   @id @default(uuid()) @db.Char(36)
  restaurantId                      String   @unique @db.Char(36)
  enabled                           Boolean  @default(true)
  minPartySize                      Int      @default(1)
  maxPartySize                      Int      @default(20)
  defaultReservationDuration        Int      @default(60)
  minAdvanceBookingMinutes          Int      @default(60)
  maxAdvanceBookingDays             Int      @default(30)
  cancellationDeadlineMinutes       Int      @default(1440)
  modificationDeadlineMinutes       Int      @default(1440)
  allowWalkIns                      Boolean  @default(true)
  autoConfirmReservations           Boolean  @default(false)
  requireCustomerPhone              Boolean  @default(false)
  requireCustomerEmail              Boolean  @default(true)
  maxActiveReservationsPerCustomer  Int      @default(10)
  gracePeriodMinutes                Int      @default(15)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("reservation_policies")
}

// ── OrganizationSetting ────────────────────────────────────────────────────
// Organization-level key-value configuration.

model OrganizationSetting {
  id             String @id @default(uuid()) @db.Char(36)
  organizationId String @db.Char(36)
  key            String @db.VarChar(100)
  value          String @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("organization_settings")
}

// ── Branch ─────────────────────────────────────────────────────────────────
// A single physical restaurant location.

model Branch {
  id                         String   @id @default(uuid()) @db.Char(36)
  organizationId             String   @db.Char(36)
  name                       String   @db.VarChar(255)
  slug                       String   @db.VarChar(100)
  address                    String?  @db.Text
  phone                      String?  @db.VarChar(20)
  email                      String?  @db.VarChar(255)
  timezone                   String   @default("UTC") @db.VarChar(50)
  cuisineType                String?  @db.VarChar(100)
  defaultDineDuration        Int      @default(90)
  slotInterval               Int      @default(30)
  maxPartySize               Int      @default(20)
  advanceBookingDays         Int      @default(30)
  minNoticeMinutes           Int      @default(60)
  autoConfirm                Boolean  @default(true)
  isOnlineReservationEnabled Boolean  @default(false)
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  updatedBy                  String?  @db.Char(36)

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tables           RestaurantTable[]
  zones            TableZone[]
  reservations     Reservation[]
  operatingHours   OperatingHour[]
  holidayHours     HolidayHour[]
  userRoles        UserRole[]
  employees        Employee[]
  notifications         Notification[]
  notificationTemplates NotificationTemplate[]
  settings              Setting[]

  @@index([organizationId])
  @@map("branches")
}

// ── OperatingHour ──────────────────────────────────────────────────────────
// Standard operating hours per day of week. 0=Sunday, 6=Saturday.

model OperatingHour {
  id        String  @id @default(uuid()) @db.Char(36)
  branchId  String  @db.Char(36)
  dayOfWeek Int
  openTime  String  @db.VarChar(5)
  closeTime String  @db.VarChar(5)
  isClosed  Boolean @default(false)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@map("operating_hours")
}

// ── HolidayHour ────────────────────────────────────────────────────────────
// Override hours for holidays and special dates.

model HolidayHour {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  String   @db.Char(36)
  date      DateTime @db.Date
  openTime  String?  @db.VarChar(5)
  closeTime String?  @db.VarChar(5)
  isClosed  Boolean  @default(false)
  reason    String?  @db.VarChar(255)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@index([date])
  @@map("holiday_hours")
}

// ============================================================================
// EMPLOYEES
// ============================================================================

// ── Employee ───────────────────────────────────────────────────────────────
// Links a User to a Branch with employment-specific fields.
// A user may work at multiple branches (with separate employee records).

model Employee {
  id           String   @id @default(uuid()) @db.Char(36)
  userId       String   @db.Char(36)
  branchId     String   @db.Char(36)
  employeeCode String?  @unique @db.VarChar(50)
  position     String   @db.VarChar(100)
  hiredAt      DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([branchId])
  @@map("employees")
}

// ============================================================================
// TABLES & ZONES
// ============================================================================

// ── TableZone ──────────────────────────────────────────────────────────────
// Groups tables into sections (patio, bar, VIP, indoor).

model TableZone {
  id          String   @id @default(uuid()) @db.Char(36)
  branchId    String   @db.Char(36)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables RestaurantTable[]

  @@unique([branchId, name])
  @@map("table_zones")
}

// ── RestaurantTable ────────────────────────────────────────────────────────
// A physical table in a restaurant. Links to Dining Area and Table Type for
// classification and floor plan layout. Supports soft delete via deletedAt.
// Status tracks real-time availability for the reservation engine.

model RestaurantTable {
  id              String   @id @default(uuid()) @db.Char(36)
  restaurantId    String   @db.Char(36)
  branchId        String   @db.Char(36)
  diningAreaId    String?  @db.Char(36)
  tableTypeId     String?  @db.Char(36)
  zoneId          String?  @db.Char(36)
  tableNumber     String   @db.VarChar(10)
  name            String?  @db.VarChar(100)
  description     String?  @db.Text
  minCapacity     Int      @default(1)
  maxCapacity     Int
  currentCapacity Int      @default(0)
  shape           String   @default("rectangle") @db.VarChar(20)
  width           Int      @default(60)
  height          Int      @default(60)
  positionX       Float?
  positionY       Float?
  rotation        Float?
  qrIdentifier    String?  @db.VarChar(100)
  isReservable    Boolean  @default(true)
  isAccessible    Boolean  @default(true)
  isActive        Boolean  @default(true)
  status          String   @default("available") @db.VarChar(20)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedBy       String?  @db.Char(36)
  deletedAt       DateTime?

  restaurant  Organization  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branch      Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  diningArea  DiningArea?   @relation(fields: [diningAreaId], references: [id], onDelete: SetNull)
  tableType   TableType?    @relation(fields: [tableTypeId], references: [id], onDelete: SetNull)
  zone        TableZone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  reservations ReservationTable[]

  @@unique([restaurantId, tableNumber])
  @@unique([restaurantId, qrIdentifier])
  @@index([restaurantId, status])
  @@index([restaurantId, diningAreaId])
  @@index([restaurantId, tableTypeId])
  @@index([restaurantId, isActive])
  @@index([branchId, status])
  @@index([branchId, tableNumber])
  @@index([zoneId])
  @@map("restaurant_tables")
}

// ── TableType ──────────────────────────────────────────────────────────────
// Reusable table classification (Standard, VIP, Booth, Bar, Outdoor, etc.).
// Defines shared characteristics for groups of physical tables.
// Soft-deletable via status.

model TableType {
  id              String   @id @default(uuid()) @db.Char(36)
  restaurantId    String   @db.Char(36)
  name            String   @db.VarChar(100)
  code            String   @db.VarChar(30)
  description     String?  @db.Text
  defaultCapacity Int      @default(4)
  minimumCapacity Int      @default(1)
  maximumCapacity Int      @default(8)
  shape           String   @default("rectangle") @db.VarChar(20)
  isReservable    Boolean  @default(true)
  displayOrder    Int      @default(0)
  status          String   @default("active") @db.VarChar(20)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables     RestaurantTable[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId, status])
  @@map("table_types")
}

// ── DiningArea ─────────────────────────────────────────────────────────────
// Physical zones or sections inside a restaurant (Main Hall, Terrace, VIP Room).
// Each area can have multiple tables. Soft-deletable via status.

model DiningArea {
  id              String   @id @default(uuid()) @db.Char(36)
  restaurantId    String   @db.Char(36)
  name            String   @db.VarChar(100)
  code            String   @db.VarChar(30)
  description     String?  @db.Text
  displayOrder    Int      @default(0)
  status          String   @default("active") @db.VarChar(20)
  isReservable    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Organization @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables     RestaurantTable[]

  @@unique([restaurantId, name])
  @@unique([restaurantId, code])
  @@index([restaurantId, status])
  @@map("dining_areas")
}

// ── TableGroup ──────────────────────────────────────────────────────────────
// Temporary grouping of 2+ tables for merge/split operations.
// Does NOT modify the RestaurantTable entity; tableId references are logical.
// Statuses: active → reserved → occupied → released → archived
// Capacity is NOT persisted — computed at runtime by GroupCapacityCalculator.

model TableGroup {
  id           String   @id @default(uuid()) @db.Char(36)
  restaurantId String   @db.Char(36)
  name         String   @db.VarChar(100)
  description  String?  @db.Text
  status       String   @default("active") @db.VarChar(20)
  isActive     Boolean  @default(true)
  createdBy    String   @db.Char(36)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  releasedAt   DateTime?

  restaurant Organization        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  members    TableGroupMember[]

  @@index([restaurantId])
  @@index([restaurantId, status])
  @@index([restaurantId, isActive])
  @@map("table_groups")
}

model TableGroupMember {
  id           String   @id @default(uuid()) @db.Char(36)
  tableGroupId String   @db.Char(36)
  tableId      String   @db.Char(36)
  displayOrder Int      @default(0)
  joinedAt     DateTime @default(now())

  tableGroup TableGroup @relation(fields: [tableGroupId], references: [id], onDelete: Cascade)

  @@unique([tableGroupId, tableId])
  @@index([tableId])
  @@index([tableGroupId])
  @@map("table_group_members")
}

// ============================================================================
// CUSTOMERS
// ============================================================================

// ── Customer ───────────────────────────────────────────────────────────────
// Diner profile. Stores contact info, preferences, and denormalized counters.
// Counters (totalVisits, totalNoShows, totalCancellations) are updated via
// triggers or application logic after reservation status changes.

model Customer {
  id                String   @id @default(uuid()) @db.Char(36)
  organizationId    String   @db.Char(36)
  firstName         String   @db.VarChar(100)
  lastName          String   @db.VarChar(100)
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(20)
  totalVisits       Int      @default(0)
  totalCancellations Int     @default(0)
  totalNoShows      Int      @default(0)
  isVip             Boolean  @default(false)
  isFlagged         Boolean  @default(false)
  notes             String?  @db.Text
  preferences       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  updatedBy         String?  @db.Char(36)

  organization Organization @relation(fields: [organizationId], references: [id])
  reservations Reservation[]

  @@index([organizationId, lastName])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([organizationId, isFlagged])
  @@map("customers")
}

// ============================================================================
// RESERVATIONS
// ============================================================================

// ── Reservation ────────────────────────────────────────────────────────────
// Central entity. A booking made by a customer at a branch.
// Status values: pending | confirmed | seated | completed | cancelled | no_show
// Supports walk-ins (walkIn=true), multi-table splits (via ReservationTable),
// and full audit trail (via ReservationStatusHistory).

model Reservation {
  id               String    @id @default(uuid()) @db.Char(36)
  organizationId   String    @db.Char(36)
  branchId         String    @db.Char(36)
  customerId       String    @db.Char(36)
  confirmationCode String   @unique @db.VarChar(20)
  partySize        Int
  reservationDate  DateTime  @db.Date
  startTime        DateTime
  endTime          DateTime
  status           String    @default("pending") @db.VarChar(20)
  specialRequests  String?   @db.Text
  notes            String?   @db.Text
  walkIn           Boolean   @default(false)
  source           String    @default("staff") @db.VarChar(20)
  createdBy        String    @db.Char(36)
  assignedTo       String?   @db.Char(36)
  cancelledAt      DateTime?
  cancelReason     String?   @db.VarChar(500)
  noShowMarkedAt   DateTime?
  seatedAt         DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  updatedBy        String?   @db.Char(36)

  organization      Organization                @relation(fields: [organizationId], references: [id])
  branch            Branch                      @relation(fields: [branchId], references: [id])
  customer          Customer                    @relation(fields: [customerId], references: [id])
  createdByUser     User                        @relation("CreatedBy", fields: [createdBy], references: [id])
  assignedToUser    User?                       @relation("AssignedTo", fields: [assignedTo], references: [id])
  updatedByUser     User?                       @relation("UpdatedBy", fields: [updatedBy], references: [id])
  tableAssignments  ReservationTable[]
  statusHistory     ReservationStatusHistory[]
  notifications     Notification[]

  @@index([branchId, reservationDate, status])
  @@index([branchId, startTime])
  @@index([customerId])
  @@index([organizationId, status])
  @@index([confirmationCode])
  @@map("reservations")
}

// ── ReservationTable ───────────────────────────────────────────────────────
// Junction — links a reservation to assigned table(s).
// Supports split parties: one reservation may occupy multiple tables.

model ReservationTable {
  reservationId String   @db.Char(36)
  tableId       String   @db.Char(36)
  assignedAt    DateTime @default(now())

  reservation Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table       RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([reservationId, tableId])
  @@index([tableId])
  @@map("reservation_tables")
}

// ── ReservationStatusHistory ───────────────────────────────────────────────
// Immutable log of every status change on a reservation.
// High-volume table — consider partitioning by created_at.

model ReservationStatusHistory {
  id            String   @id @default(uuid()) @db.Char(36)
  reservationId String   @db.Char(36)
  fromStatus    String   @db.VarChar(20)
  toStatus      String   @db.VarChar(20)
  changedBy     String?  @db.Char(36)
  reason        String?  @db.VarChar(500)
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId, createdAt])
  @@index([createdAt])
  @@map("reservation_status_history")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

// ── Notification ───────────────────────────────────────────────────────────
// Record of a notification sent to a customer (email/SMS).
// Types: confirmation | reminder | cancellation | modification

model Notification {
  id              String   @id @default(uuid()) @db.Char(36)
  organizationId  String   @db.Char(36)
  branchId        String   @db.Char(36)
  reservationId   String?  @db.Char(36)
  type            String   @db.VarChar(30)
  recipientEmail  String?  @db.VarChar(255)
  recipientPhone  String?  @db.VarChar(20)
  status          String   @default("pending") @db.VarChar(20)
  sentAt          DateTime?
  errorMessage    String?  @db.Text
  createdAt       DateTime @default(now())

  branch      Branch       @relation(fields: [branchId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([type])
  @@index([reservationId])
  @@map("notifications")
}

// ── NotificationTemplate ───────────────────────────────────────────────────
// Configurable templates for notification content.
// NULL branchId means system default template.

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  String?  @db.Char(36)
  type      String   @db.VarChar(30)
  subject   String   @db.VarChar(500)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, type])
  @@map("notification_templates")
}

// ============================================================================
// SETTINGS
// ============================================================================

// ── Setting ────────────────────────────────────────────────────────────────
// Flexible key-value configuration store. Scoped to a branch (or NULL = global).
// Supports any setting type by storing values as JSON.

model Setting {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  String?  @db.Char(36)
  key       String   @db.VarChar(100)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, key])
  @@map("settings")
}

// ============================================================================
// AUDIT
// ============================================================================

// ── AuditLog ───────────────────────────────────────────────────────────────
// Immutable system-wide event log. Records every significant action.
// High-volume table — consider partitioning by created_at.

model AuditLog {
  id              String   @id @default(uuid()) @db.Char(36)
  organizationId  String   @db.Char(36)
  userId          String?  @db.Char(36)
  action          String   @db.VarChar(100)
  entity          String   @db.VarChar(50)
  entityId        String   @db.Char(36)
  details         Json?
  ipAddress       String?  @db.VarChar(45)
  userAgent       String?  @db.VarChar(500)
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, entity, entityId])
  @@index([organizationId, action])
  @@index([userId])
  @@map("audit_logs")
}

// ── AuditEntry ─────────────────────────────────────────────────────────────
// Generic immutable audit trail. Tracks every significant action across all
// modules (restaurant, table, reservation, user, role, etc.).
// Designed as a generic module — not tied to any specific domain.

model AuditEntry {
  id              String   @id @default(uuid()) @db.Char(36)
  organizationId  String   @db.Char(36)
  module          String   @db.VarChar(50)
  entityType      String   @db.VarChar(50)
  entityId        String   @db.Char(36)
  action          String   @db.VarChar(50)
  performedBy     String?  @db.Char(36)
  restaurantId    String?  @db.Char(36)
  ipAddress       String?  @db.VarChar(45)
  userAgent       String?  @db.VarChar(500)
  requestId       String?  @db.VarChar(100)
  oldValues       Json?
  newValues       Json?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, module])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, action])
  @@index([performedBy])
  @@index([restaurantId])
  @@map("audit_entries")
}
